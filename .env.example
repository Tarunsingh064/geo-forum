# Points the frontend at the NestJS backend built earlier
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Public half of the VAPID keypair (same pair the backend uses) - safe to expose client-side.
# Generate with `npx web-push generate-vapid-keys` on the backend, then paste the public key here.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
